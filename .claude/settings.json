{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/log_usage.py\" 2>/dev/null",
            "timeout": 30,
            "statusMessage": "Logging token usage & CO2"
          }
        ]
      }
    ]
  }
}
